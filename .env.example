# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Music search/playback now talks directly to YouTube Music's own InnerTube
# API on-device (see app/src/main/java/com/example/data/youtube/ and
# data/network/InnerTubeMusicService.kt) - no YouTube Data API key, no relay/
# render server, and no config needed here for it anymore.
